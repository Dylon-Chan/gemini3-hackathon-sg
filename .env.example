# ── Backend public URL (required in production for media URLs) ────────────────
# BASE_URL=https://singflix-backend.onrender.com

# ── Option A: Gemini Developer API (AI Studio) ────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# ── Option B: Vertex AI via GCP service account ───────────────────────────────
# Download a service account JSON from IAM → Service Accounts → Keys
# Required roles: Vertex AI User, Storage Object Viewer (if using GCS videos)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Model config (shared) ──────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
VEO_MODEL=veo-3.1-generate-001

# Set to true when using Vertex AI for video downloads from GCS
USE_VERTEX_AI=true

# Concurrency / polling tuning
GEMINI_CONCURRENCY=3
VEO_POLL_INTERVAL_SECONDS=10
VEO_MAX_POLL_ATTEMPTS=60
